# Cross-platform development: normalize line endings
# This ensures consistent line endings across Windows, macOS, and Linux
# https://help.github.com/en/articles/handling-line-endings

# Auto detect text files and perform LF normalization
* text=auto

# Source code - always use LF
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
.env.* text eol=lf

# Windows-specific scripts - use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.whl binary
*.egg binary
*.so binary
*.dll binary
*.exe binary

# Pixi SCM syntax highlighting & preventing 3-way merges
pixi.lock merge=binary 
linguist-language=YAML 
linguist-generated=true -diff 
linguist-detectable=false

# Categorize Jupyter notebooks specifically as documentation
*.ipynb linguist-documentation=true
*.ipynb linguist-detectable=false
