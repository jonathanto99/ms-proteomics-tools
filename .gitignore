# --- THE SAFETY SHIELD (Global Ignore) ---
# Ignore these file types EVERYWHERE in the vault
*.pdf
*.zip
*.pptx
*.docx
*.doc
*.xlsx
*.mov
*.mp4

# Python
.venv/
.pixi/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.log
*.tsv

# Ruff
.ruff_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
.cache/

# Data files (uncomment patterns as needed)
*.raw
*.mzML
*.mzXML

# Keep frontend build for deployment
!programs/mspp_web/frontend/dist/# pixi environments
.pixi/*
!.pixi/config.toml

# pixi environments
.pixi/*
!.pixi/config.toml