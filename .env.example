# MSPP Environment Configuration
# Copy this file to .env and modify values as needed
# Note: Values in this file are defaults; set these as environment variables to override

# Flask Configuration
# ==================

# Host address to bind the Flask server to
# - 127.0.0.1 (default): localhost only, perfect for development
# - 0.0.0.0: all interfaces, use for Docker or production deployments
FLASK_HOST=127.0.0.1

# Port for the Flask backend API
# Default: 5000 (standard Flask port)
FLASK_PORT=5000

# Environment mode affects debug mode and error handling
# - production (default): debug=False, optimized performance
# - development: debug=True, auto-reload, detailed error pages
FLASK_ENV=production

# Frontend Configuration
# ======================

# Frontend dev server port (used during development only)
# Default: 3000 (standard React dev server port)
VITE_PORT=3000

# Frontend API proxy target (points to Flask backend)
# Default: http://localhost:5000
VITE_API_PROXY=http://localhost:5000

# CORS Configuration
# ==================

# Allowed origins for CORS (comma-separated)
# Use in development to allow requests from different hosts/ports
# Examples:
#   - http://localhost:3000,http://localhost:5000 (local dev)
#   - https://example.com,https://www.example.com (production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Temporary Directory
# ===================

# Custom temporary directory for uploaded files
# By default, uses the system temp directory (platform-specific)
# - Windows: C:\Users\<user>\AppData\Local\Temp
# - macOS/Linux: /tmp
# Set this to use a custom directory:
# MSPP_TEMP_DIR=/custom/path/to/temp

# Application Configuration
# ==========================

# Maximum file upload size (in bytes)
# Default: 16777216 (16 MB)
# MAX_CONTENT_LENGTH=16777216

# Data Processing
# ===============

# Optional: add custom data processing configuration here
# For example, organism patterns, expected ratios, etc.
# These might be used in future releases
